# Beehiiv publication ID (not secret — found in Beehiiv Settings, looks like "pub_00000000-0000-0000-0000-000000000000").
# Copy this file to ".env" in this same functions/ folder and fill in the real value.
# The API key itself is NOT set here — it's stored separately as a Cloud Functions
# secret via `firebase functions:secrets:set BEEHIIV_API_KEY`.
BEEHIIV_PUBLICATION_ID=
